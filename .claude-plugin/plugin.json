{
  "name": "astra",
  "version": "0.1.0",
  "description": "AST-powered codebase memory for AI agents. Cuts token usage 93% by injecting only relevant code context via knowledge graph + PageRank.",
  "author": { "name": "Satya Sai Charan" },
  "license": "MIT",
  "mcpServers": {
    "astra": {
      "command": "/Library/Frameworks/Python.framework/Versions/3.14/bin/python3",
      "args": ["-m", "astra.mcp.server"],
      "env": {
        "ASTRA_DATA_DIR": "${workspaceFolder}/.astra",
        "ASTRA_PROJECT": "${workspaceFolder}"
      }
    }
  },
  "setup": {
    "command": "bash",
    "args": ["${pluginRoot}/install.sh"]
  }
}
